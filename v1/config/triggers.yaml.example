# Trigger configuration — what wakes the scheduler up unprompted.
#
# This file is the COMMITTED TEMPLATE. The real config lives in
# config/triggers.yaml (gitignored). Generate the live file by running
# ./install.sh and walking through the triggers step, or hand-copy
# this template and edit.
#
# The scheduler re-reads the live file on every tick (~30s), so changes
# take effect within seconds — no daemon restart needed.

# Real-time email triage
# ──────────────────────
# Every unread email from a non-automated sender is run through one
# Haiku 4.5 call ("triage"). Haiku decides whether the email is worth
# a phone notification AND produces structured "ping items" — one
# self-contained, action-shaped blurb per actionable thing in the
# email. A single email can produce multiple items (school newsletter
# covering both a field trip and Field Day → two pings).
#
# There is no sender allowlist and no urgency-keyword list any more.
# Haiku reads the body in context. If you've used previous versions of
# this file and have `important_senders` / `urgency_keywords` blocks,
# they're now ignored — feel free to delete them.

email_triggers:

  # Master switch. False = scheduler doesn't poll Gmail at all.
  enabled: true

  # How often the scheduler checks for new unread email.
  # Lower = faster pings, more Gmail API + Haiku calls.
  every_minutes: 15

  # Per-fire cap on Haiku calls. Caps the worst-case cost on a
  # pathological bulk-mail day. Each call is ~$0.001, so the practical
  # ceiling at 30 is ~$0.03/fire (~$3/day at 15-minute cadence).
  llm_classification:
    max_per_check: 30

# Expected arrivals (gap detection)
# ─────────────────────────────────
# Watches the inbox for emails you EXPECT to receive ahead of known
# upcoming events. When the event is within `lead_time_days` and no
# matching email has arrived, the scheduler pings you with a "heads
# up, no prep materials yet" alert. Each watch fires at most once per
# day (re-checks until the event passes or the expected email lands).
#
# Disabled by default. Add entries that match your life — meetings
# you sit on, regular deliveries, school-year boundaries, etc.

expected_arrivals:
  enabled: false
  cadence_hours: 12
  watches: []
  # Example entry:
  # - name: "Board meeting prep"
  #   event_date: "2026-05-18"
  #   expected_sender: "chair@example.org"
  #   sender_label: "Chair"          # optional — friendlier than the email
  #   expected_subject: "Meeting"   # substring match on subject
  #   lead_time_days: 7

# Delivery watch
# ──────────────
# Carrier "out for delivery / delivered" alerts. Stricter AND match
# (carrier sender AND delivery keyword) so routine "your account was
# updated" carrier emails don't ping you. Empty senders/keywords lists
# fall back to the defaults baked into scheduler/triggers.py — UPS,
# FedEx, Amazon, USPS, DHL + standard delivery-today phrases.
#
# Alerted deliveries are also logged as `delivery_today` facts so the
# morning brief can roll them up without re-querying Gmail.

delivery_watch:

  # Master switch.
  enabled: true

  # How often to poll Gmail for new carrier emails. Delivery windows
  # change less frequently than urgency emails, so 30 min is plenty.
  every_minutes: 30

  # Sender substrings to match (case-insensitive against From: header).
  # Leave empty to use the defaults: ups.com, fedex.com, amazon.com,
  # usps.com, informeddelivery.usps.com, dhl.com.
  senders: []

  # Keywords to require in subject/snippet. Leave empty for defaults:
  # "out for delivery", "delivering today", "scheduled to deliver
  # today", "arriving today", "your delivery today", "delivery today",
  # "delivered".
  keywords: []

# Scheduled briefings
# ───────────────────
# All times are in USER_TIMEZONE from .env.

scheduled:

  morning_brief:
    enabled: true
    # 24-hour local time. Default 07:30; the user wants between 7-9am.
    time: "07:30"
    # If true, skip Saturday and Sunday.
    weekdays_only: false
    # What to include in the brief.
    include:
      - todays_calendar
      - top_tasks
      - urgent_unread_emails

  weekly_review:
    enabled: true
    day: sunday
    time: "20:00"
    include:
      - incomplete_tasks_last_week
      - upcoming_week_calendar

# Group-chat third-party retention (ROADMAP M3)
# ─────────────────────────────────────────────
# When you opt iMessage group chats in via IMESSAGE_GROUP_CHATS, the
# relay archives messages from OTHER group members so the agent can
# answer questions about the thread. Those messages get tagged at
# archive time with `is_third_party=1`. The scheduler runs a daily
# purge that deletes them after `group_chat_retention_days`.
#
# Your own messages (typed from any device on your Apple ID) and the
# agent's replies are NEVER subject to this purge — only content
# authored by someone else.
#
# Set to 0 to keep third-party messages forever (NOT recommended;
# they're other people's content sitting in your local DB).

group_chat:
  group_chat_retention_days: 30

# Audit-log retention (ROADMAP H2 fallback)
# ─────────────────────────────────────────
# `api_events` is the table where every Claude API turn — user
# message, assistant reply, tool call, tool result, vision request —
# gets archived verbatim. It's there so you can audit what the agent
# saw and produced. It's also the table that accumulates the most
# personal data over time.
#
# Whole-DB encryption (SQLCipher) was the preferred fix but doesn't
# have precompiled wheels for arm64 macOS + Python 3.13 yet. As a
# stand-in, the scheduler runs a daily purge that drops api_events
# rows older than this many days. Conversations, messages, facts,
# and reminders are never touched here — those stay indefinitely.
#
# Set to 0 to disable the purge entirely (keep the audit log forever).

audit_log:
  audit_log_retention_days: 30

# Overdue task reminders (deferred — set enabled: true if you want hourly nudges)
overdue_check:
  enabled: false
  cadence_minutes: 60
  # Only ping for priority >= this value. Todoist priority: 1=lowest, 4=urgent.
  min_priority: 3
