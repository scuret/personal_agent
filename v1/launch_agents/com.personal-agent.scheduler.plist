<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.personal-agent.scheduler</string>

    <key>ProgramArguments</key>
    <array>
        <string>__V1_DIR__/.venv/bin/python</string>
        <string>-m</string>
        <string>scheduler.triggers</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__V1_DIR__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>__V1_DIR__/data/scheduler.log</string>
    <key>StandardErrorPath</key>
    <string>__V1_DIR__/data/scheduler.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
