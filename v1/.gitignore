# Secrets and credentials. Block every .env* variant (editor backups,
# shell-quoting accidents like ".env\", per-env files like .env.local)
# but explicitly keep .env.example as the committed template.
.env
.env*
!.env.example
config/credentials.json

# Live trigger config — contains personal allowlists (sender emails,
# keyword lists). Committed template lives at config/triggers.yaml.example;
# the live file is generated by install.sh.
config/triggers.yaml

# Cached OAuth tokens and runtime state
data/*.pickle
data/*.sqlite
data/*.sqlite-journal
data/*.sqlite-shm
data/*.sqlite-wal
data/*.db
data/*.log
# rotated log backups from tools/rotate_logs.py — they have date suffixes
data/*.log.*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# macOS
.DS_Store

# Editors
.vscode/
.idea/
*.swp
*~
