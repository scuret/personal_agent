# Copy this to .env and fill in. Never commit .env.

# --- Required ---

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Todoist API key (Todoist > Settings > Integrations > Developer)
TODOIST_API_KEY=

# Notion integration token (notion.so/profile/integrations → New integration → "Internal").
# After getting the token, you must also CONNECT each page/database you want
# the agent to access: in Notion, open the page → ⋯ menu → Connections → add
# your integration. Notion's permission model is opt-in per page.
NOTION_INTEGRATION_TOKEN=

# GitHub personal access token (github.com/settings/tokens).
# Classic with `repo` scope OR fine-grained with Issues read+write,
# Pull requests read, Contents read, Metadata read.
GITHUB_TOKEN=

# Brave Search API key (api.search.brave.com → Subscribe Free → API Keys).
# Free tier: 2K queries/month at 1 q/s. Powers the web_search tool which
# fills the gap for factual / current-events questions outside our other
# integrations.
BRAVE_SEARCH_API_KEY=

# YouTube Data API v3 key. Get one at console.cloud.google.com → enable
# "YouTube Data API v3" → Credentials → Create credentials → API key.
# This is SEPARATE from your OAuth credentials.json — just an API key.
# Free quota: 10K units/day (search costs 100 units, video lookup 1).
YOUTUBE_API_KEY=

# Dropbox access token. Get one at dropbox.com/developers/apps → create
# a Scoped Access app, set permissions (files.metadata.read +
# files.content.read at minimum, sharing.* if you want share-link
# creation), then Settings → Generated access token → Generate.
DROPBOX_ACCESS_TOKEN=

# Path to Google OAuth client credentials JSON downloaded from Google Cloud Console.
# Default location keeps the file in config/ (gitignored).
GOOGLE_OAUTH_CREDENTIALS_PATH=./config/credentials.json

# Path where the Gmail/Calendar OAuth token gets cached after first auth.
GOOGLE_OAUTH_TOKEN_PATH=./data/google_token.pickle

# --- Behavior ---

# IANA timezone string. Used for "morning brief" scheduling and date formatting.
USER_TIMEZONE=America/Chicago

# The Claude model to use. Default to a strong general-purpose Sonnet for cost/latency balance.
# Switch to claude-opus-4-7 for harder reasoning tasks; claude-haiku-4-5-20251001 for cheap routing.
CLAUDE_MODEL=claude-sonnet-4-6

# --- iMessage relay (only used when imessage_relay.py is running) ---

# Two modes:
#   contact  — relay listens for messages from a single sender (TARGET_PHONE_NUMBER)
#              who is texting your Apple ID. Use when someone else (or a
#              dedicated test device) talks to the agent.
#   self     — relay listens to your OWN messages in note-to-self chats so
#              you can text your own agent from your iPhone. Outgoing replies
#              are tagged with a zero-width space so the relay skips them on
#              the next read pass (loop prevention). Use SELF_HANDLES if you
#              want extra self-handles watched (e.g. your Apple ID email).
IMESSAGE_MODE=contact

# In contact mode: the OTHER person's handle (the sender you want the agent to
# respond to). Format: +15555551234 or apple-id@icloud.com.
# In self mode: YOUR primary handle, used as both the watched chat identifier
# and the destination for replies.
TARGET_PHONE_NUMBER=

# self mode only — extra handles to watch alongside TARGET_PHONE_NUMBER.
# Comma-separated. Useful if you text yourself from your phone but also use
# your Apple ID email for the same purpose.
# Example: SELF_HANDLES=you@icloud.com
SELF_HANDLES=

# Polling cadence in seconds for new iMessages. Lower = more responsive, more CPU.
IMESSAGE_POLL_INTERVAL=5
