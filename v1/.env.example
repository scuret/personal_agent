# Copy this to .env and fill in. Never commit .env.
#
# Only ANTHROPIC_API_KEY is strictly required — the agent will run with
# just that, you'll just have fewer tools available. Add the others as
# you decide which sub-agents to enable.
#
# ─── SECURITY ───────────────────────────────────────────────────────────────
# Treat every value below like a password.
#
#   * NEVER paste a real key into chat (iMessage, Slack, ChatGPT, this
#     repo's PRs, etc.), screenshots, or cloud-synced docs.
#   * If a key has touched any of those surfaces, rotate it. Each
#     provider's revoke/regenerate procedure is in README.md → "Key
#     rotation + handling discipline".
#   * Rotate every key at least once per quarter even with no known
#     exposure.
#   * The .gitignore already protects this file from being committed.
#     Don't override it.


# ─── CORE (required) ────────────────────────────────────────────────────────

# Anthropic API key — powers the agent itself.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=


# ─── Sub-agent integrations (all optional) ──────────────────────────────────

# Todoist API token. https://todoist.com/app/settings/integrations/developer
TODOIST_API_KEY=

# Notion integration token. https://www.notion.so/profile/integrations
# Create an Internal integration, then SHARE each page/db with it via
# the page's ⋯ menu → Connections. Notion permission is opt-in per page.
NOTION_INTEGRATION_TOKEN=

# GitHub personal access token. https://github.com/settings/tokens
# Classic with `repo` scope, OR fine-grained with Issues r+w / PRs r /
# Contents r / Metadata r.
GITHUB_TOKEN=

# Brave Search API key. https://api.search.brave.com
# Subscribe → Free tier (2K queries/month at 1 q/s). Free but requires
# a credit card on file.
BRAVE_SEARCH_API_KEY=

# YouTube Data API v3 key. https://console.cloud.google.com
# Enable "YouTube Data API v3" → Credentials → Create credentials →
# API key. Free quota: 10K units/day. SEPARATE from your Google OAuth
# credentials.json — this is just an API key.
YOUTUBE_API_KEY=

# Dropbox app credentials. https://www.dropbox.com/developers/apps
# Create a Scoped Access app. Permissions tab — set: files.metadata.read,
# files.content.read, sharing.read (optionally sharing.write). Submit.
# Settings tab:
#   • Add `http://localhost:53682` to "Redirect URIs" (exact match).
#   • Copy "App key" → DROPBOX_APP_KEY, reveal "App secret" → DROPBOX_APP_SECRET.
# Then run `python -m mcp_servers.dropbox_auth` once to grant access; that
# caches a long-lived refresh token at DROPBOX_TOKEN_PATH and the agent
# auto-refreshes 4-hour access tokens from there forever.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_TOKEN_PATH=./data/dropbox_token.json

# Google Maps Platform API key. Optional — leave blank to fall back to
# the free OpenStreetMap provider (Nominatim + OSRM, no auth). For
# Google, enable Places API, Geocoding API, and Distance Matrix API
# on a Google Cloud project, then create an API key. Free tier covers
# personal use; requires a billing account on file.
GOOGLE_MAPS_API_KEY=

# Optional: home address used as a default origin for "drive time"
# queries. The agent treats `origin: "home"` as this value.
USER_HOME_ADDRESS=

# Eight Sleep account credentials. UNOFFICIAL API — Eight Sleep doesn't
# publish a developer API; this sub-agent talks to the same endpoints
# the iOS app uses. Could break without notice if they change them.
# Leave blank to skip the sub-agent entirely.
EIGHT_EMAIL=
EIGHT_PASSWORD=
EIGHT_TOKEN_PATH=./data/eight_token.json

# Spotify app credentials. https://developer.spotify.com/dashboard
# Create app → set Redirect URI to http://127.0.0.1:8765 (must be
# exactly that — Spotify rejects `localhost` as of 2025). Copy Client
# ID + Client Secret here. Then run `python -m mcp_servers.spotify_auth`
# once at the Mac for browser consent; refresh tokens get cached at
# SPOTIFY_TOKEN_PATH and re-up the 1-hour access tokens automatically.
# Playback control requires a Spotify Premium account.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_TOKEN_PATH=./data/spotify_token.json

# Canva app credentials. https://developer.canva.com
# Create an integration → Authentication → add Redirect URL
# EXACTLY: http://127.0.0.1:8767. Configure scopes (design:meta:read,
# design:content:read, design:content:write, folder:read, asset:read,
# profile:read). Copy Client ID + Client Secret. Then run
# `python -m mcp_servers.canva_auth` once at the Mac for browser
# consent; OAuth refresh-token flow auto-refreshes 4-hour access tokens.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_TOKEN_PATH=./data/canva_token.json

# LinkedIn app credentials. https://www.linkedin.com/developers/apps
# Create app → Auth tab → add Authorized redirect URL EXACTLY:
# http://127.0.0.1:8768. Products tab → request "Sign In with
# LinkedIn using OpenID Connect" + "Share on LinkedIn" (both
# auto-approved). Copy Client ID + Client Secret. Then run
# `python -m mcp_servers.linkedin_auth` once at the Mac.
# IMPORTANT: LinkedIn personal-tier doesn't issue refresh tokens —
# the cached access token lasts 60 days, then you re-run the consent.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_TOKEN_PATH=./data/linkedin_token.json


# ─── Google OAuth (Gmail + Calendar) ────────────────────────────────────────
#
# Setup:
#   1. https://console.cloud.google.com → create project, enable Gmail
#      API + Google Calendar API.
#   2. APIs & Services → Credentials → Create OAuth client ID →
#      Desktop app. Download the JSON, save as config/credentials.json.
#   3. Run `python -m mcp_servers.google_auth` once to do the browser
#      consent flow. Token gets cached at the path below.

GOOGLE_OAUTH_CREDENTIALS_PATH=./config/credentials.json
GOOGLE_OAUTH_TOKEN_PATH=./data/google_token.pickle


# ─── Semantic recall (local embeddings) ───────────────────────────────────
# The agent's memory layer uses sentence-transformers to embed messages
# and facts at archive time, then finds them via cosine similarity in
# memory_search_conversations + memory_recall_facts. Local-only, no API
# key needed. First call downloads ~440MB on disk and uses ~500MB RAM.
#
# Alternates: BAAI/bge-small-en-v1.5 (130MB, ~5% quality drop) or
# BAAI/bge-large-en-v1.5 (1.3GB, marginal quality bump). Switching
# models invalidates existing embeddings — run
# `python -m tools.backfill_embeddings` after the change.
EMBEDDER_MODEL=BAAI/bge-base-en-v1.5

# ─── Behavior ───────────────────────────────────────────────────────────────

# IANA timezone string. Used for scheduling and date formatting.
USER_TIMEZONE=America/Chicago

# Claude model. Default Sonnet for cost/latency balance.
# Switch to claude-opus-4-7 for harder tasks; claude-haiku-4-5-20251001
# for cheap routing/triage.
CLAUDE_MODEL=claude-sonnet-4-6


# ─── Relay transport ────────────────────────────────────────────────────────
#
# Picks which messaging surface the agent uses:
#   imessage  — macOS only, via chat.db + AppleScript. Requires Full
#               Disk Access + Automation permissions for the daemon.
#   telegram  — cross-platform, no Mac required. You create a Telegram
#               bot via @BotFather and the agent talks through it.
#   discord   — cross-platform. Discord bot you create at
#               discord.com/developers/applications; DMs only.
#   slack     — Slack bot in a workspace you control, via Socket Mode
#               (no public webhook URL needed); DMs only.
#
# Only one transport runs at a time. Switching is a .env change plus
# `launchctl kickstart -k gui/$(id -u)/com.personal-agent.relay`.
RELAY_TRANSPORT=imessage


# ─── iMessage transport (RELAY_TRANSPORT=imessage) ──────────────────────────

# Two modes:
#   contact — relay listens for messages from a single sender
#             (TARGET_PHONE_NUMBER) who is texting your Apple ID.
#             Use for testing or letting someone else talk to the agent.
#   self    — relay listens to your OWN messages in note-to-self chats so
#             you can text your own agent from your iPhone. Outgoing
#             replies are tagged with a zero-width space so the relay
#             skips its own messages on the next read pass.
IMESSAGE_MODE=self

# In contact mode: the OTHER person's handle.
# In self mode: YOUR primary handle (also the destination for replies).
# Format: +15555551234 or apple-id@icloud.com.
TARGET_PHONE_NUMBER=

# self-mode only: extra handles to watch alongside TARGET_PHONE_NUMBER.
# Comma-separated. Useful if you text yourself across both phone number
# and Apple ID email.
# Example: SELF_HANDLES=you@icloud.com
SELF_HANDLES=

# Polling cadence in seconds. Lower = more responsive, more CPU.
IMESSAGE_POLL_INTERVAL=5


# ─── Telegram transport (RELAY_TRANSPORT=telegram) ──────────────────────────
#
# Setup (web/phone only, no Mac access required):
#   1. In Telegram, find @BotFather and send /newbot. Pick a display
#      name + username (must end in `bot`). BotFather replies with a
#      token — paste it as TELEGRAM_BOT_TOKEN below.
#   2. Find YOUR Telegram user ID. Easiest path: search @userinfobot
#      in Telegram, start it, copy the numeric id it replies with.
#      Add it to TELEGRAM_ALLOWED_USER_IDS (comma-separated for
#      multiple). The bot ignores messages from anyone not on this
#      list.
#   3. Send /start to your bot once from your phone so Telegram
#      allows it to message you back.

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Optional: chat_id where scheduled briefs / reminders go. Defaults to
# the first id in TELEGRAM_ALLOWED_USER_IDS. Override only if you want
# briefs to land in a group chat the bot is part of.
TELEGRAM_BRIEF_CHAT_ID=


# ─── Discord transport (RELAY_TRANSPORT=discord) ──────────────────────────
#
# Setup (web only):
#   1. discord.com/developers/applications → New Application → name it
#      (e.g. "personal_agent") → Save.
#   2. Bot tab → Add Bot. Toggle "Message Content Intent" ON (privileged
#      — required to read DM bodies). Reset Token → copy → paste below.
#   3. OAuth2 → URL Generator:
#         Scopes: bot
#         Bot Permissions: Send Messages, Read Message History, Attach Files
#      Open the generated URL → pick a server you admin (a private
#      personal-agent server is fine) → authorize.
#   4. In Discord, enable Developer Mode (User Settings → Advanced →
#      Developer Mode on). Right-click yourself → Copy User ID. Add
#      below (comma-separated for multiple).
#   5. DM the bot once from a channel in that shared server to start
#      the DM thread.

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=

# Optional: recipient id for scheduled briefs / reminders. Defaults to
# the first id in DISCORD_ALLOWED_USER_IDS.
DISCORD_BRIEF_RECIPIENT_ID=


# ─── Slack transport (RELAY_TRANSPORT=slack) ──────────────────────────────
#
# Uses Socket Mode — Slack opens a WebSocket back to this daemon, so
# there's no public webhook URL to set up. Setup (web only):
#   1. api.slack.com/apps → Create New App → From scratch → name
#      "personal_agent" → pick a workspace you control.
#   2. Socket Mode → Enable → create an App-Level Token named
#      "personal_agent_socket" with scope `connections:write`. Copy
#      it (xapp-…) into SLACK_APP_TOKEN below.
#   3. OAuth & Permissions → Bot Token Scopes → add:
#         chat:write, im:history, im:read, files:read, users:read
#      Install to Workspace. Copy the Bot User OAuth Token (xoxb-…)
#      into SLACK_BOT_TOKEN below.
#   4. Event Subscriptions → Enable Events → subscribe to bot events:
#         message.im
#      Save.
#   5. Find your Slack user id: profile → ⋯ → "Copy member ID"
#      (Uxxxxxxxx). Add below.

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USER_IDS=

# Optional: user id where scheduled briefs / reminders DM. Defaults to
# the first id in SLACK_ALLOWED_USER_IDS.
SLACK_BRIEF_USER_ID=
