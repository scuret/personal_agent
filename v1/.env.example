# Copy this to .env and fill in. Never commit .env.
#
# Only ANTHROPIC_API_KEY is strictly required — the agent will run with
# just that, you'll just have fewer tools available. Add the others as
# you decide which sub-agents to enable.


# ─── CORE (required) ────────────────────────────────────────────────────────

# Anthropic API key — powers the agent itself.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=


# ─── Sub-agent integrations (all optional) ──────────────────────────────────

# Todoist API token. https://todoist.com/app/settings/integrations/developer
TODOIST_API_KEY=

# Notion integration token. https://www.notion.so/profile/integrations
# Create an Internal integration, then SHARE each page/db with it via
# the page's ⋯ menu → Connections. Notion permission is opt-in per page.
NOTION_INTEGRATION_TOKEN=

# GitHub personal access token. https://github.com/settings/tokens
# Classic with `repo` scope, OR fine-grained with Issues r+w / PRs r /
# Contents r / Metadata r.
GITHUB_TOKEN=

# Brave Search API key. https://api.search.brave.com
# Subscribe → Free tier (2K queries/month at 1 q/s). Free but requires
# a credit card on file.
BRAVE_SEARCH_API_KEY=

# YouTube Data API v3 key. https://console.cloud.google.com
# Enable "YouTube Data API v3" → Credentials → Create credentials →
# API key. Free quota: 10K units/day. SEPARATE from your Google OAuth
# credentials.json — this is just an API key.
YOUTUBE_API_KEY=

# Dropbox access token. https://www.dropbox.com/developers/apps
# Create a Scoped Access app. Permissions tab — set: files.metadata.read,
# files.content.read, sharing.read (optionally sharing.write). Submit.
# Settings tab → Generate access token. NOTE: tokens prefixed with
# `sl.u.` are short-lived (~4h); long-term use needs an OAuth refresh
# flow (TBD).
DROPBOX_ACCESS_TOKEN=


# ─── Google OAuth (Gmail + Calendar) ────────────────────────────────────────
#
# Setup:
#   1. https://console.cloud.google.com → create project, enable Gmail
#      API + Google Calendar API.
#   2. APIs & Services → Credentials → Create OAuth client ID →
#      Desktop app. Download the JSON, save as config/credentials.json.
#   3. Run `python -m mcp_servers.google_auth` once to do the browser
#      consent flow. Token gets cached at the path below.

GOOGLE_OAUTH_CREDENTIALS_PATH=./config/credentials.json
GOOGLE_OAUTH_TOKEN_PATH=./data/google_token.pickle


# ─── Behavior ───────────────────────────────────────────────────────────────

# IANA timezone string. Used for scheduling and date formatting.
USER_TIMEZONE=America/Chicago

# Claude model. Default Sonnet for cost/latency balance.
# Switch to claude-opus-4-7 for harder tasks; claude-haiku-4-5-20251001
# for cheap routing/triage.
CLAUDE_MODEL=claude-sonnet-4-6


# ─── iMessage relay (only when relay/imessage_relay.py is running) ──────────

# Two modes:
#   contact — relay listens for messages from a single sender
#             (TARGET_PHONE_NUMBER) who is texting your Apple ID.
#             Use for testing or letting someone else talk to the agent.
#   self    — relay listens to your OWN messages in note-to-self chats so
#             you can text your own agent from your iPhone. Outgoing
#             replies are tagged with a zero-width space so the relay
#             skips its own messages on the next read pass.
IMESSAGE_MODE=self

# In contact mode: the OTHER person's handle.
# In self mode: YOUR primary handle (also the destination for replies).
# Format: +15555551234 or apple-id@icloud.com.
TARGET_PHONE_NUMBER=

# self-mode only: extra handles to watch alongside TARGET_PHONE_NUMBER.
# Comma-separated. Useful if you text yourself across both phone number
# and Apple ID email.
# Example: SELF_HANDLES=you@icloud.com
SELF_HANDLES=

# Polling cadence in seconds. Lower = more responsive, more CPU.
IMESSAGE_POLL_INTERVAL=5
